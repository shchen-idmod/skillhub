# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Comma-separated list of origins allowed to call the API directly.
# In production behind Nginx, the browser talks to Nginx (same origin),
# so CORS is only relevant for direct API access (e.g. curl, mobile apps).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to false in production
DEBUG=false

# Optional GitHub personal access token (read-only scope is enough).
# Without it, GitHub API is limited to 60 requests/hour — easily hit when
# importing repos with many files. With it: 5000/hour.
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=
